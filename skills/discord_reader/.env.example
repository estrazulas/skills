# Token de autenticação do Discord
# Como obter:
# 1. Abra https://discord.com/app no navegador e faça login
# 2. F12 > Network > clique em qualquer requisição
# 3. Copie o valor do header "authorization"
DISCORD_TOKEN="seu_token_aqui"

# Canal padrão (opcional) - ID numérico do canal
# Extraia do link: https://discord.com/channels/SERVIDOR/CANAL
DISCORD_DEFAULT_CHANNEL=""
